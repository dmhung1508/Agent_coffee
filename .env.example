# Required
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Public menu API
COFFEE_API_BASE_URL=https://api-coffee.8am.vn

# Context / summary
COFFEE_AGENT_MAX_CONTEXT_CHARS=6000
SUMMARY_KEEP_TAIL_TURNS=4
SUMMARY_THRESHOLD_CHARS=6000

# Menu cache
MENU_CACHE_TTL_SECONDS=600
MENU_CACHE_MAX_SIZE=512

# Browse enrichment
BROWSE_ENRICH_TOP_N=3

# Last catalog invalidation
LAST_CATALOG_OVERLAP_THRESHOLD=0.3

# Observability
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LOG_LEVEL=INFO
LOG_JSON=true

# Fast-path
FAST_PATH_ENABLED=true

# Sessions
SESSION_TTL_SECONDS=3600
SESSION_MAX_COUNT=1000

# Order log
ORDER_LOG_PATH=logs/orders.jsonl

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
CORS_ALLOWED_ORIGINS=*
